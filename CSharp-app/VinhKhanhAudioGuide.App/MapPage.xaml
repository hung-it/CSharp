<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:VinhKhanhAudioGuide.App"
             x:Class="VinhKhanhAudioGuide.App.MapPage"
             Title="Bản đồ POI"
             BackgroundColor="#FFF5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Frame Grid.Row="0" BackgroundColor="#FF69B4" CornerRadius="0" Padding="16" HasShadow="False">
            <StackLayout>
                <Label Text="🗺️ Bản đồ POI" FontSize="22" FontAttributes="Bold" TextColor="White" 
                       HorizontalOptions="Center"/>
                <Label x:Name="GpsStatusLabel" Text="⏳ Đang xác định vị trí..." 
                       FontSize="14" TextColor="White" HorizontalOptions="Center" Margin="0,4,0,0"/>
            </StackLayout>
        </Frame>

        <!-- GPS Status -->
        <Frame Grid.Row="1" BackgroundColor="White" CornerRadius="0" Padding="12" HasShadow="False">
            <StackLayout Orientation="Horizontal" HorizontalOptions="Center">
                <ActivityIndicator x:Name="GpsActivityIndicator" Color="#FF69B4" 
                                   WidthRequest="20" HeightRequest="20"/>
                <Label x:Name="GpsDetailLabel" Text="Đang lấy tọa độ GPS..." 
                       FontSize="14" TextColor="#666" VerticalOptions="Center" Margin="8,0,0,0"/>
            </StackLayout>
        </Frame>

        <!-- Map Area (Placeholder) -->
        <Frame Grid.Row="2" BackgroundColor="#F5F5F5" CornerRadius="16" Margin="16" HasShadow="True">
            <StackLayout VerticalOptions="Center" HorizontalOptions="Center">
                <Label Text="🗺️" FontSize="64" HorizontalOptions="Center"/>
                <Label Text="Bản đồ đang được tải..." FontSize="16" TextColor="#999" 
                       HorizontalOptions="Center" Margin="0,8,0,0"/>
                <Label x:Name="CurrentLocationLabel" Text="📍 Vị trí hiện tại: ---" 
                       FontSize="12" TextColor="#666" HorizontalOptions="Center" Margin="0,8,0,0"/>
            </StackLayout>
        </Frame>

        <!-- Nearby Section -->
        <Frame Grid.Row="2" BackgroundColor="Transparent" Margin="0" Padding="0" 
               VerticalOptions="Start" HorizontalOptions="Start">
            <StackLayout Margin="16">
                <Label Text="📍 Gần bạn" FontSize="16" FontAttributes="Bold" TextColor="#FF69B4" 
                       BackgroundColor="White" Padding="8,4"/>
                <ScrollView Orientation="Horizontal" Margin="0,8,0,0">
                    <StackLayout x:Name="NearbyPoiContainer" Orientation="Horizontal" Spacing="8">
                        <!-- Dynamic POIs will be added here -->
                    </StackLayout>
                </ScrollView>
            </StackLayout>
        </Frame>

        <!-- Bottom Actions -->
        <Frame Grid.Row="3" BackgroundColor="White" CornerRadius="20" Margin="16" Padding="12" HasShadow="True">
            <StackLayout>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Text="🔄 Làm mới" 
                            BackgroundColor="#FFB6C1" TextColor="#333" 
                            CornerRadius="20" Margin="4,0"
                            Clicked="RefreshButton_Clicked"/>
                    <Button Grid.Column="1" Text="📷 Quét QR" 
                            BackgroundColor="#FFB6C1" TextColor="#333" 
                            CornerRadius="20" Margin="4,0"
                            Clicked="QrScanButton_Clicked"/>
                    <Button Grid.Column="2" Text="📍 POI" 
                            BackgroundColor="#FF69B4" TextColor="White" 
                            CornerRadius="20" Margin="4,0"
                            Clicked="PoiListButton_Clicked"/>
                </Grid>
            </StackLayout>
        </Frame>
    </Grid>

</ContentPage>
