<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhAudioGuide.App.MapPage"
             BackgroundColor="#FFFBF5">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- 📌 Header -->
        <Border Grid.Row="0" BackgroundColor="White" StrokeThickness="0" Padding="16,12">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                <VerticalStackLayout Grid.Column="0" Spacing="2">
                    <Label Text="🗺️ Bản đồ POI" FontSize="18" FontAttributes="Bold"
                           TextColor="#1F2937" />
                    <Label x:Name="LocationStatusLabel" Text="⏳ Đang xác định vị trí..." FontSize="11"
                           TextColor="#6B7280" />
                </VerticalStackLayout>
                <Button Grid.Column="1" Text="📍 Vị trí" BackgroundColor="#3B82F6"
                        TextColor="White" CornerRadius="20" HeightRequest="40"
                        Padding="12,8" Clicked="OnCenterLocationClicked" />
            </Grid>
        </Border>

        <!-- 🗺️ WebView Map -->
        <WebView x:Name="mapWebView" Grid.Row="1" HorizontalOptions="Fill" VerticalOptions="Fill" />

        <!-- 📋 Bottom Panel -->
        <Border Grid.Row="2" BackgroundColor="White" StrokeThickness="0"
                StrokeShape="RoundRectangle 20,20,0,0" Padding="16">
            <VerticalStackLayout Spacing="12">

                <!-- 📍 Gần bạn -->
                <VerticalStackLayout Spacing="8">
                    <Label Text="📍 Gần bạn" FontSize="14" FontAttributes="Bold"
                           TextColor="#1F2937" />
                    <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                        <HorizontalStackLayout x:Name="NearbyPoiStack" Spacing="10">
                        </HorizontalStackLayout>
                    </ScrollView>
                </VerticalStackLayout>

                <!-- 🎯 Nút chức năng -->
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                    <Button Grid.Column="0" Text="🔄 Làm mới" BackgroundColor="#F3F4F6"
                            TextColor="#374151" CornerRadius="10" HeightRequest="44"
                            Clicked="OnRefreshMapClicked" />
                    <Button Grid.Column="1" Text="📷 Quét QR" BackgroundColor="#FCE7F3"
                            TextColor="#BE185D" CornerRadius="10" HeightRequest="44"
                            Clicked="OnScanQRClicked" />
                    <Button Grid.Column="2" Text="📍 POI" BackgroundColor="#ECFDF5"
                            TextColor="#047857" CornerRadius="10" HeightRequest="44"
                            Clicked="OnShowAllPoiClicked" />
                </Grid>

            </VerticalStackLayout>
        </Border>

    </Grid>

</ContentPage>
