<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhAudioGuide.App.TourManagerPage"
             BackgroundColor="{StaticResource Pink50}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="10">
            <Label Text="Quản Lý Tour" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource Pink900}" HorizontalOptions="Center" />
            <CollectionView x:Name="TourCollectionView"
                             SelectionMode="Single"
                             SelectionChanged="OnTourSelected">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="{StaticResource Pink100}" CornerRadius="10"
                               Padding="14" Margin="0,0,0,4" HasShadow="False">
                            <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout Grid.Column="0" Spacing="4">
                                    <Label Text="{Binding Name}" FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource Pink800}" />
                                    <Label Text="{Binding Description}" FontSize="12"
                                           TextColor="{StaticResource Pink600}" />
                                    <Label Text="{Binding StopCountText}" FontSize="11"
                                           TextColor="{StaticResource Pink400}" />
                                </VerticalStackLayout>
                                <Label Grid.Column="1" Text="›" FontSize="22"
                                       TextColor="{StaticResource Pink400}"
                                       VerticalOptions="Center" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>