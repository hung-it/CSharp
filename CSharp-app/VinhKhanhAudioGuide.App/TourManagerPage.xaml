<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhAudioGuide.App.TourManagerPage"
             Title="Tuyến Tour"
             BackgroundColor="#FFF5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Frame Grid.Row="0" BackgroundColor="#FF69B4" CornerRadius="0" Padding="16" HasShadow="False">
            <StackLayout>
                <Label Text="✈️ Tuyến Tour" FontSize="22" FontAttributes="Bold" TextColor="White" 
                       HorizontalOptions="Center"/>
            </StackLayout>
        </Frame>

        <ScrollView Grid.Row="1">
            <StackLayout Padding="16" Spacing="16">

                <!-- My Tours Stats -->
                <Frame BackgroundColor="White" CornerRadius="12" Padding="16" HasShadow="True">
                    <StackLayout>
                        <Label Text="📊 Tour của bạn" FontSize="18" FontAttributes="Bold" TextColor="#333"/>
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackLayout Grid.Column="0" HorizontalOptions="Center">
                                <Label x:Name="ToursCompletedLabel" Text="0" FontSize="28" FontAttributes="Bold" 
                                       TextColor="#FF69B4" HorizontalOptions="Center"/>
                                <Label Text="tour đã làm" FontSize="11" TextColor="#666" HorizontalOptions="Center"/>
                            </StackLayout>
                            <StackLayout Grid.Column="1" HorizontalOptions="Center">
                                <Label x:Name="PoisVisitedLabel" Text="0" FontSize="28" FontAttributes="Bold" 
                                       TextColor="#FF69B4" HorizontalOptions="Center"/>
                                <Label Text="điểm đã ghé" FontSize="11" TextColor="#666" HorizontalOptions="Center"/>
                            </StackLayout>
                            <StackLayout Grid.Column="2" HorizontalOptions="Center">
                                <Label x:Name="AudioListenedLabel" Text="0" FontSize="28" FontAttributes="Bold" 
                                       TextColor="#FF69B4" HorizontalOptions="Center"/>
                                <Label Text="audio đã nghe" FontSize="11" TextColor="#666" HorizontalOptions="Center"/>
                            </StackLayout>
                        </Grid>
                    </StackLayout>
                </Frame>

                <!-- District Tours -->
                <Label Text="🏘️ Các tuyến tour" FontSize="18" FontAttributes="Bold" TextColor="#333"/>

                <!-- Xóm Chiếu Tour -->
                <Frame BackgroundColor="White" CornerRadius="12" Padding="16" HasShadow="True">
                    <StackLayout>
                        <StackLayout Orientation="Horizontal">
                            <Label Text="🏘️" FontSize="32"/>
                            <StackLayout Margin="12,0,0,0">
                                <Label Text="Tuyến Xóm Chiếu" FontSize="18" FontAttributes="Bold" TextColor="#333"/>
                                <Label Text="Khám phá ẩm thực truyền thống" FontSize="12" TextColor="#666"/>
                            </StackLayout>
                        </StackLayout>
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackLayout Grid.Column="0">
                                <Label Text="📍" FontSize="20" HorizontalOptions="Center"/>
                                <Label x:Name="XomChieuStopsLabel" Text="5" FontSize="16" FontAttributes="Bold" 
                                       TextColor="#FF69B4" HorizontalOptions="Center"/>
                                <Label Text="điểm dừng" FontSize="10" TextColor="#666" HorizontalOptions="Center"/>
                            </StackLayout>
                            <StackLayout Grid.Column="1">
                                <Label Text="⏱️" FontSize="20" HorizontalOptions="Center"/>
                                <Label Text="2" FontSize="16" FontAttributes="Bold" 
                                       TextColor="#FF69B4" HorizontalOptions="Center"/>
                                <Label Text="thời gian" FontSize="10" TextColor="#666" HorizontalOptions="Center"/>
                            </StackLayout>
                            <StackLayout Grid.Column="2">
                                <Label Text="📏" FontSize="20" HorizontalOptions="Center"/>
                                <Label Text="Dễ" FontSize="16" FontAttributes="Bold" 
                                       TextColor="#FF69B4" HorizontalOptions="Center"/>
                                <Label Text="độ khó" FontSize="10" TextColor="#666" HorizontalOptions="Center"/>
                            </StackLayout>
                        </Grid>
                        <Button Text="🚀 Bắt đầu tour" BackgroundColor="#FF69B4" TextColor="White" 
                                CornerRadius="20" Margin="0,12,0,0" Clicked="StartXomChieuTour_Clicked"/>
                    </StackLayout>
                </Frame>

                <!-- Vĩnh Hội Tour -->
                <Frame BackgroundColor="White" CornerRadius="12" Padding="16" HasShadow="True">
                    <StackLayout>
                        <StackLayout Orientation="Horizontal">
                            <Label Text="🏠" FontSize="32"/>
                            <StackLayout Margin="12,0,0,0">
                                <Label Text="Tuyến Vĩnh Hội" FontSize="18" FontAttributes="Bold" TextColor="#333"/>
                                <Label Text="Di sản văn hóa lịch sử" FontSize="12" TextColor="#666"/>
                            </StackLayout>
                        </StackLayout>
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackLayout Grid.Column="0">
                                <Label Text="📍" FontSize="20" HorizontalOptions="Center"/>
                                <Label x:Name="VinhHoiStopsLabel" Text="7" FontSize="16" FontAttributes="Bold" 
                                       TextColor="#FF69B4" HorizontalOptions="Center"/>
                                <Label Text="điểm dừng" FontSize="10" TextColor="#666" HorizontalOptions="Center"/>
                            </StackLayout>
                            <StackLayout Grid.Column="1">
                                <Label Text="⏱️" FontSize="20" HorizontalOptions="Center"/>
                                <Label Text="3" FontSize="16" FontAttributes="Bold" 
                                       TextColor="#FF69B4" HorizontalOptions="Center"/>
                                <Label Text="thời gian" FontSize="10" TextColor="#666" HorizontalOptions="Center"/>
                            </StackLayout>
                            <StackLayout Grid.Column="2">
                                <Label Text="📏" FontSize="20" HorizontalOptions="Center"/>
                                <Label Text="Trung bình" FontSize="14" FontAttributes="Bold" 
                                       TextColor="#FF69B4" HorizontalOptions="Center"/>
                                <Label Text="độ khó" FontSize="10" TextColor="#666" HorizontalOptions="Center"/>
                            </StackLayout>
                        </Grid>
                        <Button Text="🚀 Bắt đầu tour" BackgroundColor="#FF69B4" TextColor="White" 
                                CornerRadius="20" Margin="0,12,0,0" Clicked="StartVinhHoiTour_Clicked"/>
                    </StackLayout>
                </Frame>

                <!-- Khánh Hội Tour -->
                <Frame BackgroundColor="White" CornerRadius="12" Padding="16" HasShadow="True">
                    <StackLayout>
                        <StackLayout Orientation="Horizontal">
                            <Label Text="🏪" FontSize="32"/>
                            <StackLayout Margin="12,0,0,0">
                                <Label Text="Tuyến Khánh Hội" FontSize="18" FontAttributes="Bold" TextColor="#333"/>
                                <Label Text="Chợ truyền thống &amp; ẩm thực đường phố" FontSize="12" TextColor="#666"/>
                            </StackLayout>
                        </StackLayout>
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackLayout Grid.Column="0">
                                <Label Text="📍" FontSize="20" HorizontalOptions="Center"/>
                                <Label x:Name="KhanhHoiStopsLabel" Text="6" FontSize="16" FontAttributes="Bold" 
                                       TextColor="#FF69B4" HorizontalOptions="Center"/>
                                <Label Text="điểm dừng" FontSize="10" TextColor="#666" HorizontalOptions="Center"/>
                            </StackLayout>
                            <StackLayout Grid.Column="1">
                                <Label Text="⏱️" FontSize="20" HorizontalOptions="Center"/>
                                <Label Text="2.5" FontSize="16" FontAttributes="Bold" 
                                       TextColor="#FF69B4" HorizontalOptions="Center"/>
                                <Label Text="thời gian" FontSize="10" TextColor="#666" HorizontalOptions="Center"/>
                            </StackLayout>
                            <StackLayout Grid.Column="2">
                                <Label Text="📏" FontSize="20" HorizontalOptions="Center"/>
                                <Label Text="Dễ" FontSize="16" FontAttributes="Bold" 
                                       TextColor="#FF69B4" HorizontalOptions="Center"/>
                                <Label Text="độ khó" FontSize="10" TextColor="#666" HorizontalOptions="Center"/>
                            </StackLayout>
                        </Grid>
                        <Button Text="🚀 Bắt đầu tour" BackgroundColor="#FF69B4" TextColor="White" 
                                CornerRadius="20" Margin="0,12,0,0" Clicked="StartKhanhHoiTour_Clicked"/>
                    </StackLayout>
                </Frame>

                <!-- Tips Section -->
                <Frame BackgroundColor="#FFFACD" CornerRadius="12" Padding="16" HasShadow="True">
                    <StackLayout>
                        <StackLayout Orientation="Horizontal">
                            <Label Text="💡" FontSize="24"/>
                            <Label Text="Mẹo" FontSize="18" FontAttributes="Bold" TextColor="#666" 
                                   VerticalOptions="Center" Margin="8,0,0,0"/>
                        </StackLayout>
                        <Label Text="🎧 Bật audio guide để nghe thuyết minh khi đến mỗi điểm dừng" 
                               FontSize="14" TextColor="#666" Margin="0,8,0,0"/>
                        <Label Text="📍 GPS sẽ tự động phát audio khi bạn đến gần điểm tham quan" 
                               FontSize="14" TextColor="#666" Margin="0,4,0,0"/>
                        <Label Text="🔋 Nhớ sạc pin và mang tai nghe để có trải nghiệm tốt nhất!" 
                               FontSize="14" TextColor="#666" Margin="0,4,0,0"/>
                    </StackLayout>
                </Frame>

                <!-- Spacer -->
                <BoxView HeightRequest="50"/>

            </StackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
