<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhAudioGuide.App.SettingsPage"
             BackgroundColor="#FFFBF5"
             Title="Tài khoản">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">

            <!-- 👤 Thông tin tài khoản -->
            <Border BackgroundColor="#EC4899" StrokeThickness="0"
                    StrokeShape="RoundRectangle 16" Padding="20">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0" BackgroundColor="White"
                                StrokeThickness="0" StrokeShape="RoundRectangle 30"
                                WidthRequest="60" HeightRequest="60">
                            <Label Text="👤" FontSize="28"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                            <Label x:Name="UsernameLabel" Text="Khách" FontSize="18"
                                   FontAttributes="Bold" TextColor="White" />
                            <Label x:Name="PlanBadgeLabel" Text="[Basic] Giới hạn"
                                   FontSize="12" TextColor="#FDF2F8" />
                        </VerticalStackLayout>
                        <Button Grid.Column="2" x:Name="LoginLogoutBtn" Text="🔑 Đăng nhập"
                                BackgroundColor="White" TextColor="#EC4899"
                                FontSize="12" CornerRadius="20" Padding="16,8"
                                Clicked="OnLoginLogoutClicked" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- 🎯 Trạng thái đăng nhập -->
            <Label x:Name="LoginStatusLabel" Text="⚠️ Vui lòng đăng nhập để sử dụng đầy đủ tính năng Premium"
                   FontSize="12" TextColor="#6B7280" HorizontalOptions="Center"
                   IsVisible="True" />

            <!-- 🚀 Nâng cấp Premium - Hiển thị cho người dùng Basic -->
            <Border x:Name="UpgradeBanner" BackgroundColor="#7C3AED" StrokeThickness="0"
                    StrokeShape="RoundRectangle 16" Padding="20"
                    IsVisible="True">
                <VerticalStackLayout Spacing="12">
                    <Label Text="💎 Nâng cấp Premium" FontSize="20" FontAttributes="Bold"
                           TextColor="White" HorizontalOptions="Center" />
                    <Label Text="Mở khóa: Audio tiếng Anh 🇬🇧 | Chế độ Offline 📥 | GPS thông minh 📍"
                           FontSize="13" TextColor="#EDE9FE" HorizontalOptions="Center" />
                    <Button Text="⚡ Nâng cấp ngay - 10 USD/tháng"
                            BackgroundColor="#FDE68A" TextColor="#5B21B6" FontSize="14"
                            FontAttributes="Bold" CornerRadius="20" HeightRequest="48"
                            Clicked="OnUpgradeClicked" />
                </VerticalStackLayout>
            </Border>

            <!-- 🌐 Ngôn ngữ -->
            <Border BackgroundColor="White" StrokeThickness="0"
                    StrokeShape="RoundRectangle 12" Padding="16">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="Auto,*">
                        <Label Grid.Column="0" Text="🌐 Ngôn ngữ" FontSize="15" FontAttributes="Bold"
                               TextColor="#374151" />
                        <Label Grid.Column="1" Text="[Premium]"
                               FontSize="10" TextColor="#DC2626" FontAttributes="Bold"
                               HorizontalOptions="End" VerticalOptions="Center"
                               IsVisible="False" />
                    </Grid>

                    <HorizontalStackLayout Spacing="10">
                        <Button x:Name="LangViBtn" Text="🇻🇳 Tiếng Việt" BackgroundColor="#EC4899"
                                TextColor="White" CornerRadius="20" FontSize="13" Padding="16,10"
                                Clicked="OnLanguageViClicked" />
                        <Button x:Name="LangEnBtn" Text="🇬🇧 English" BackgroundColor="#E5E7EB"
                                TextColor="#374151" CornerRadius="20" FontSize="13" Padding="16,10"
                                Clicked="OnLanguageEnClicked" />
                    </HorizontalStackLayout>

                    <!-- 🔒 Thông báo Premium cho English -->
                    <Border x:Name="EnglishPremiumNotice" BackgroundColor="#FEF3C7" StrokeThickness="0"
                            StrokeShape="RoundRectangle 8" Padding="10" IsVisible="True">
                        <HorizontalStackLayout Spacing="6">
                            <Label Text="🔒" FontSize="14" VerticalOptions="Center" />
                            <Label Text="Audio tiếng Anh là tính năng Premium"
                                   FontSize="12" TextColor="#92400E" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- 📍 GPS & Vị trí -->
            <Border x:Name="GpsSensitivitySection" BackgroundColor="White" StrokeThickness="0"
                    StrokeShape="RoundRectangle 12" Padding="16" IsVisible="True">
                <VerticalStackLayout Spacing="12">

                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label Grid.Column="0" Text="📍 GPS &amp; Vị trí" FontSize="15" FontAttributes="Bold"
                               TextColor="#374151" />
                        <Label Grid.Column="2" x:Name="GpsPremiumBadge" Text="[Premium]"
                               FontSize="10" TextColor="#DC2626" FontAttributes="Bold"
                               HorizontalOptions="End" VerticalOptions="Center" IsVisible="True" />
                    </Grid>

                    <!-- 🤖 Tự động phát audio -->
                    <Grid x:Name="AutoPlayRow" ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="🤖 Tự động phát audio" FontSize="13" TextColor="#1F2937" />
                            <Label Text="Tự động phát khi vào bán kính POI" FontSize="11" TextColor="#6B7280" />
                        </VerticalStackLayout>
                        <Switch Grid.Column="1" x:Name="AutoPlaySwitch" IsToggled="False"
                                OnColor="#EC4899" ThumbColor="White" Toggled="OnAutoPlayToggled" />
                    </Grid>

                    <!-- 📏 Độ nhạy GPS -->
                    <Grid x:Name="GpsSensitivityRow" ColumnDefinitions="*,Auto" IsVisible="True">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="📏 Độ nhạy GPS" FontSize="13" TextColor="#1F2937" />
                            <Label Text="Khoảng cách để kích hoạt thuyết minh" FontSize="11" TextColor="#6B7280" />
                        </VerticalStackLayout>
                        <Label Grid.Column="1" x:Name="GpsSensitivityLabel" Text="50m" FontSize="13"
                               TextColor="#EC4899" VerticalOptions="Center" />
                    </Grid>
                    <Slider x:Name="GpsSensitivitySlider" Minimum="20" Maximum="100"
                            Value="50" ValueChanged="OnGpsSensitivityChanged"
                            MinimumTrackColor="#EC4899" MaximumTrackColor="#E5E7EB"
                            IsVisible="True" />
                </VerticalStackLayout>
            </Border>

            <!-- 🎧 Audio -->
            <Border BackgroundColor="White" StrokeThickness="0"
                    StrokeShape="RoundRectangle 12" Padding="16">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="Auto,*">
                        <Label Grid.Column="0" Text="🎧 Audio" FontSize="15" FontAttributes="Bold"
                               TextColor="#374151" />
                        <Label Grid.Column="1" x:Name="AudioPremiumBadge" Text="[Premium]"
                               FontSize="10" TextColor="#DC2626" FontAttributes="Bold"
                               HorizontalOptions="End" VerticalOptions="Center" IsVisible="True" />
                    </Grid>

                    <!-- 🔊 Loại audio ưu tiên -->
                    <Grid x:Name="AudioTypeRow" ColumnDefinitions="*,Auto" IsVisible="True">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="🔊 Loại audio ưu tiên" FontSize="13" TextColor="#1F2937" />
                            <Label Text="Chọn giữa ghi âm &amp; Text-to-Speech" FontSize="11" TextColor="#6B7280" />
                        </VerticalStackLayout>
                        <Picker x:Name="AudioTypePicker" FontSize="12" WidthRequest="140"
                                SelectedIndexChanged="OnAudioTypeChanged">
                            <Picker.Items>
                                <x:String>🎙️ Ghi âm sẵn</x:String>
                                <x:String>🤖 Text-to-Speech</x:String>
                                <x:String>🔁 Ưu tiên ghi âm</x:String>
                            </Picker.Items>
                        </Picker>
                    </Grid>

                    <!-- 🔈 Âm lượng -->
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="🔈 Âm lượng" FontSize="13" TextColor="#1F2937" />
                            <Label Text="Điều chỉnh âm lượng phát audio" FontSize="11" TextColor="#6B7280" />
                        </VerticalStackLayout>
                        <Label Grid.Column="1" x:Name="VolumeLabel" Text="80%" FontSize="13"
                               TextColor="#EC4899" VerticalOptions="Center" />
                    </Grid>
                    <Slider x:Name="VolumeSlider" Minimum="0" Maximum="100"
                            Value="80" ValueChanged="OnVolumeChanged"
                            MinimumTrackColor="#EC4899" MaximumTrackColor="#E5E7EB" />
                </VerticalStackLayout>
            </Border>

            <!-- 📥 Dữ liệu & Đồng bộ - Premium Only -->
            <Border x:Name="OfflineModeSection" BackgroundColor="White" StrokeThickness="0"
                    StrokeShape="RoundRectangle 12" Padding="16" IsVisible="True">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="Auto,*">
                        <Label Grid.Column="0" Text="📥 Dữ liệu &amp; Đồng bộ" FontSize="15" FontAttributes="Bold"
                               TextColor="#374151" />
                        <Label Grid.Column="1" x:Name="OfflinePremiumBadge" Text="[Premium]"
                               FontSize="10" TextColor="#DC2626" FontAttributes="Bold"
                               HorizontalOptions="End" VerticalOptions="Center" IsVisible="True" />
                    </Grid>

                    <!-- 🗄️ Chế độ Offline -->
                    <Grid x:Name="OfflineToggleRow" ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="🗄️ Chế độ Offline" FontSize="13" TextColor="#1F2937" />
                            <Label Text="Tải POI &amp; audio khi có WiFi" FontSize="11" TextColor="#6B7280" />
                        </VerticalStackLayout>
                        <Switch x:Name="OfflineModeSwitch" IsToggled="False"
                                OnColor="#EC4899" ThumbColor="White" Toggled="OnOfflineModeToggled" />
                    </Grid>

                    <!-- 📲 Tải dữ liệu offline -->
                    <Button x:Name="DownloadOfflineBtn" Text="📥 Tải dữ liệu offline"
                            BackgroundColor="#EFF6FF" TextColor="#2563EB" FontSize="13"
                            CornerRadius="10" HeightRequest="44" IsVisible="True"
                            Clicked="OnDownloadOfflineClicked" />

                    <!-- 🗑️ Xóa cache -->
                    <Button Text="🗑️ Xóa dữ liệu cache"
                            BackgroundColor="#FEF2F2" TextColor="#DC2626" FontSize="13"
                            CornerRadius="10" HeightRequest="44"
                            Clicked="OnClearCacheClicked" />
                </VerticalStackLayout>
            </Border>

            <!-- ℹ️ Thông tin ứng dụng -->
            <Border BackgroundColor="White" StrokeThickness="0"
                    StrokeShape="RoundRectangle 12" Padding="16">
                <VerticalStackLayout Spacing="12">
                    <Label Text="ℹ️ Thông tin ứng dụng" FontSize="15" FontAttributes="Bold"
                           TextColor="#374151" />

                    <Grid ColumnDefinitions="*,*">
                        <Label Grid.Column="0" Text="📌 Phiên bản" FontSize="13" TextColor="#6B7280" />
                        <Label Grid.Column="1" Text="1.0.0" FontSize="13" TextColor="#1F2937"
                               HorizontalOptions="End" />
                    </Grid>

                    <Grid ColumnDefinitions="*,*">
                        <Label Grid.Column="0" Text="🆔 User ID" FontSize="13" TextColor="#6B7280" />
                        <Label Grid.Column="1" x:Name="UserIdLabel" Text="Đang tải..."
                               FontSize="11" TextColor="#1F2937" HorizontalOptions="End" />
                    </Grid>

                    <Button Text="🌐 Mở Web Admin"
                            BackgroundColor="#F3F4F6" TextColor="#374151" FontSize="13"
                            CornerRadius="10" HeightRequest="44"
                            Clicked="OnOpenAdminWebClicked" />
                </VerticalStackLayout>
            </Border>

            <!-- 💬 Hỗ trợ -->
            <Border BackgroundColor="#FEF3C7" StrokeThickness="0"
                    StrokeShape="RoundRectangle 12" Padding="16">
                <VerticalStackLayout Spacing="8">
                    <Label Text="💬 Hỗ trợ &amp; Phản hồi" FontSize="13" FontAttributes="Bold"
                           TextColor="#92400E" />
                    <Label Text="📧 Email: support@vinhkhanh.vn"
                           FontSize="12" TextColor="#B45309" />
                    <Label Text="📍 Địa chỉ: Phố Ăn Vĩnh Khách, Quận 4, TP.HCM"
                           FontSize="12" TextColor="#B45309" />
                    <Label Text="⭐ Nếu bạn hài lòng, hãy đánh giá 5 sao nhé!"
                           FontSize="12" TextColor="#92400E" FontAttributes="Bold" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
