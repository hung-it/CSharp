<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:VinhKhanhAudioGuide.App"
             x:Class="VinhKhanhAudioGuide.App.SettingsPage"
             Title="Tài khoản"
             BackgroundColor="#FFF5F5">

    <ScrollView>
        <StackLayout Padding="16" Spacing="16">

            <!-- Header Banner -->
            <Frame BackgroundColor="#FF69B4" CornerRadius="16" Padding="20" HasShadow="True">
                <StackLayout>
                    <Label Text="👤 Tài khoản" FontSize="24" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
                    <Label x:Name="UserNameLabel" Text="Khách" FontSize="16" TextColor="White" HorizontalOptions="Center" Margin="0,8,0,0"/>
                    <Button x:Name="LoginLogoutButton" Text="🔑 Đăng nhập" 
                            BackgroundColor="White" TextColor="#FF69B4" 
                            CornerRadius="20" Margin="0,12,0,0"
                            Clicked="LoginLogoutButton_Clicked"/>
                </StackLayout>
            </Frame>

            <!-- Premium Upgrade Banner -->
            <Frame BackgroundColor="Linear Gradient" CornerRadius="12" Padding="16" HasShadow="True">
                <Frame.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FFD700" Offset="0"/>
                        <GradientStop Color="#FFA500" Offset="1"/>
                    </LinearGradientBrush>
                </Frame.Background>
                <StackLayout Orientation="Horizontal">
                    <Label Text="💎" FontSize="32" VerticalOptions="Center"/>
                    <StackLayout VerticalOptions="Center" HorizontalOptions="FillAndExpand">
                        <Label Text="Nâng cấp Premium" FontSize="18" FontAttributes="Bold" TextColor="White"/>
                        <Label Text="⚡ Audio tiếng Anh, Chế độ Offline, Thống kê nâng cao" FontSize="12" TextColor="White"/>
                    </StackLayout>
                    <Button Text="✨ Nâng cấp" BackgroundColor="White" TextColor="#FF8C00" 
                            CornerRadius="15" Clicked="UpgradeButton_Clicked"/>
                </StackLayout>
            </Frame>

            <!-- Language Section -->
            <Frame BackgroundColor="White" CornerRadius="12" Padding="16" HasShadow="True">
                <StackLayout>
                    <Label Text="🌐 Ngôn ngữ" FontSize="18" FontAttributes="Bold" TextColor="#333"/>
                    <StackLayout Orientation="Horizontal" HorizontalOptions="Center" Margin="0,12,0,0">
                        <Button x:Name="VietnameseButton" Text="🇻🇳 Tiếng Việt" 
                                BackgroundColor="#FF69B4" TextColor="White" 
                                CornerRadius="20" Margin="4,0"
                                Clicked="VietnameseButton_Clicked"/>
                        <Button x:Name="EnglishButton" Text="🇬🇧 English" 
                                BackgroundColor="#E0E0E0" TextColor="#333" 
                                CornerRadius="20" Margin="4,0"
                                Clicked="EnglishButton_Clicked"/>
                    </StackLayout>
                </StackLayout>
            </Frame>

            <!-- GPS Section -->
            <Frame BackgroundColor="White" CornerRadius="12" Padding="16" HasShadow="True">
                <StackLayout>
                    <Label Text="📍 Vị trí" FontSize="18" FontAttributes="Bold" TextColor="#333"/>
                    
                    <StackLayout Orientation="Horizontal" Margin="0,12,0,0">
                        <Label Text="⚡ Tự động phát audio" VerticalOptions="Center" FontSize="14" TextColor="#333"/>
                        <Switch x:Name="AutoPlaySwitch" Toggled="AutoPlaySwitch_Toggled" 
                                HorizontalOptions="EndAndExpand" OnColor="#FF69B4"/>
                    </StackLayout>
                    
                    <StackLayout Margin="0,8,0,0">
                        <Label Text="📏 Độ nhạy GPS" FontSize="14" TextColor="#333"/>
                        <Slider x:Name="GpsSensitivitySlider" Minimum="1" Maximum="5" 
                                Value="3" ThumbColor="#FF69B4" 
                                MinimumTrackColor="#FFB6C1" MaximumTrackColor="#E0E0E0"
                                ValueChanged="GpsSensitivitySlider_ValueChanged"/>
                        <Label x:Name="GpsSensitivityLabel" Text="Trung bình" FontSize="12" 
                               TextColor="#666" HorizontalOptions="Center"/>
                    </StackLayout>
                </StackLayout>
            </Frame>

            <!-- Audio Section -->
            <Frame BackgroundColor="White" CornerRadius="12" Padding="16" HasShadow="True">
                <StackLayout>
                    <Label Text="🔈 Âm thanh" FontSize="18" FontAttributes="Bold" TextColor="#333"/>
                    
                    <StackLayout Orientation="Horizontal" Margin="0,12,0,0">
                        <Label Text="🔈 Âm lượng" VerticalOptions="Center" FontSize="14" TextColor="#333"/>
                        <Slider x:Name="VolumeSlider" Minimum="0" Maximum="100" 
                                Value="80" ThumbColor="#FF69B4"
                                MinimumTrackColor="#FFB6C1" MaximumTrackColor="#E0E0E0"
                                HorizontalOptions="FillAndExpand" Margin="12,0,0,0"/>
                    </StackLayout>
                    
                    <StackLayout Orientation="Horizontal" Margin="0,8,0,0">
                        <Label Text="🤖 Text-to-Speech" VerticalOptions="Center" FontSize="14" TextColor="#333"/>
                        <Switch x:Name="TtsSwitch" Toggled="TtsSwitch_Toggled" 
                                HorizontalOptions="EndAndExpand" OnColor="#FF69B4"/>
                    </StackLayout>
                </StackLayout>
            </Frame>

            <!-- Offline Section -->
            <Frame BackgroundColor="White" CornerRadius="12" Padding="16" HasShadow="True">
                <StackLayout>
                    <Label Text="🗄️ Chế độ Offline" FontSize="18" FontAttributes="Bold" TextColor="#333"/>
                    
                    <StackLayout Orientation="Horizontal" Margin="0,12,0,0">
                        <Label Text="❌ Chế độ Offline" VerticalOptions="Center" FontSize="14" TextColor="#333"/>
                        <Switch x:Name="OfflineModeSwitch" Toggled="OfflineModeSwitch_Toggled" 
                                HorizontalOptions="EndAndExpand" OnColor="#FF69B4"/>
                    </StackLayout>
                    
                    <Button x:Name="DownloadOfflineButton" Text="📥 Tải dữ liệu offline" 
                            BackgroundColor="#FF69B4" TextColor="White" 
                            CornerRadius="20" Margin="0,12,0,0"
                            Clicked="DownloadOfflineButton_Clicked"/>
                </StackLayout>
            </Frame>

            <!-- App Info Section -->
            <Frame BackgroundColor="White" CornerRadius="12" Padding="16" HasShadow="True">
                <StackLayout>
                    <Label Text="ℹ️ Thông tin ứng dụng" FontSize="18" FontAttributes="Bold" TextColor="#333"/>
                    
                    <StackLayout Orientation="Horizontal" Margin="0,12,0,0">
                        <Label Text="⭐ Phiên bản" FontSize="14" TextColor="#333"/>
                        <Label x:Name="VersionLabel" Text="1.0.0" FontSize="14" TextColor="#666" 
                               HorizontalOptions="EndAndExpand"/>
                    </StackLayout>
                    
                    <StackLayout Orientation="Horizontal" Margin="0,8,0,0">
                        <Label Text="🔒 User ID" FontSize="14" TextColor="#333"/>
                        <Label x:Name="UserIdLabel" Text="---" FontSize="14" TextColor="#666" 
                               HorizontalOptions="EndAndExpand"/>
                    </StackLayout>
                </StackLayout>
            </Frame>

            <!-- Support Section -->
            <Frame BackgroundColor="White" CornerRadius="12" Padding="16" HasShadow="True">
                <StackLayout>
                    <Label Text="💬 Hỗ trợ" FontSize="18" FontAttributes="Bold" TextColor="#333"/>
                    
                    <StackLayout Orientation="Horizontal" Margin="0,12,0,0">
                        <Label Text="📧 Email" FontSize="14" TextColor="#333"/>
                        <Label Text="support@phoananhvinhkhach.vn" FontSize="14" TextColor="#FF69B4" 
                               HorizontalOptions="EndAndExpand"/>
                    </StackLayout>
                    
                    <StackLayout Orientation="Horizontal" Margin="0,8,0,0">
                        <Label Text="🌐 Địa chỉ" FontSize="14" TextColor="#333"/>
                        <Label Text="123 Đường ABC, Quận 1, TP.HCM" FontSize="14" TextColor="#666" 
                               HorizontalOptions="EndAndExpand"/>
                    </StackLayout>
                </StackLayout>
            </Frame>

            <!-- Spacer -->
            <BoxView HeightRequest="50"/>

        </StackLayout>
    </ScrollView>

</ContentPage>
