<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="VinhKhanhAudioGuide.App.AudioPlayerPage"
             BackgroundColor="{StaticResource Pink50}"
             Title="Nghe Audio">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20">

            <!-- POI Info -->
            <Frame BackgroundColor="{StaticResource Pink100}" CornerRadius="12" Padding="20">
                <VerticalStackLayout Spacing="8">
                    <Label x:Name="PoiNameLabel" Text="Đang tải..." FontSize="22"
                           FontAttributes="Bold" TextColor="{StaticResource Pink900}"
                           HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                    <Label x:Name="PoiCodeLabel" Text="" FontSize="13"
                           TextColor="{StaticResource Pink500}" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Frame>

            <!-- Audio Player -->
            <Frame BackgroundColor="White" CornerRadius="12" Padding="20">
                <VerticalStackLayout Spacing="16">

                    <!-- Album art placeholder -->
                    <Frame BackgroundColor="{StaticResource Pink200}" CornerRadius="60"
                           WidthRequest="120" HeightRequest="120"
                           HorizontalOptions="Center" Padding="0">
                        <Label x:Name="PlayingIcon" Text="🎵" FontSize="48"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                    </Frame>

                    <!-- Status -->
                    <Label x:Name="StatusLabel" Text="Sẵn sàng phát"
                           FontSize="14" TextColor="{StaticResource Pink600}"
                           HorizontalOptions="Center" />

                    <!-- Duration -->
                    <Label x:Name="DurationLabel" Text=""
                           FontSize="12" TextColor="{StaticResource Pink400}"
                           HorizontalOptions="Center" />

                    <!-- MediaElement (ẩn, chỉ phát audio) -->
                    <toolkit:MediaElement x:Name="MediaPlayer"
                                         IsVisible="False"
                                         ShouldAutoPlay="False"
                                         ShouldShowPlaybackControls="False"
                                         MediaEnded="OnMediaEnded" />

                    <!-- Controls -->
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="16">
                        <Button x:Name="PlayPauseButton"
                                Text="▶ Phát"
                                BackgroundColor="{StaticResource Pink500}"
                                TextColor="White"
                                CornerRadius="25"
                                WidthRequest="120" HeightRequest="50"
                                Clicked="OnPlayPauseClicked"
                                IsEnabled="False" />

                        <Button Text="⏹ Dừng"
                                BackgroundColor="{StaticResource Pink300}"
                                TextColor="White"
                                CornerRadius="25"
                                WidthRequest="120" HeightRequest="50"
                                Clicked="OnStopClicked" />
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Frame>

            <!-- Language selector -->
            <Frame BackgroundColor="White" CornerRadius="12" Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Ngôn ngữ" FontSize="14" FontAttributes="Bold"
                           TextColor="{StaticResource Pink800}" />
                    <HorizontalStackLayout Spacing="10">
                        <Button x:Name="BtnVi" Text="🇻🇳 Tiếng Việt"
                                BackgroundColor="{StaticResource Pink500}" TextColor="White"
                                CornerRadius="8" FontSize="13"
                                Clicked="OnLanguageViClicked" />
                        <Button x:Name="BtnEn" Text="🇬🇧 English"
                                BackgroundColor="{StaticResource Pink200}" TextColor="{StaticResource Pink800}"
                                CornerRadius="8" FontSize="13"
                                Clicked="OnLanguageEnClicked" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
