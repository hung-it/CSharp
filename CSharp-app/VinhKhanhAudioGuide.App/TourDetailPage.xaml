<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhAudioGuide.App.TourDetailPage"
             BackgroundColor="{StaticResource Pink50}"
             Title="{Binding .}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">

            <!-- Tour info -->
            <Frame BackgroundColor="{StaticResource Pink100}" CornerRadius="12"
                   Padding="16" HasShadow="False">
                <VerticalStackLayout Spacing="6">
                    <Label x:Name="TourNameLabel" FontSize="22" FontAttributes="Bold"
                           TextColor="{StaticResource Pink900}" />
                    <Label x:Name="TourDescLabel" FontSize="13"
                           TextColor="{StaticResource Pink600}" />
                    <Label x:Name="StopCountLabel" FontSize="12"
                           TextColor="{StaticResource Pink400}" />
                </VerticalStackLayout>
            </Frame>

            <!-- Stops list -->
            <Label Text="📍 Các điểm dừng" FontSize="15" FontAttributes="Bold"
                   TextColor="{StaticResource Pink800}" />

            <CollectionView x:Name="StopsCollectionView"
                            SelectionMode="Single"
                            SelectionChanged="OnStopSelected">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="White" CornerRadius="10"
                               Padding="14" Margin="0,0,0,6" HasShadow="False">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <!-- Số thứ tự -->
                                <Frame Grid.Column="0"
                                       BackgroundColor="{StaticResource Pink500}"
                                       CornerRadius="16" Padding="0"
                                       WidthRequest="32" HeightRequest="32"
                                       HasShadow="False">
                                    <Label Text="{Binding Sequence}" FontSize="13"
                                           FontAttributes="Bold" TextColor="White"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Frame>

                                <VerticalStackLayout Grid.Column="1" Spacing="3"
                                                     VerticalOptions="Center">
                                    <Label Text="{Binding PoiName}" FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource Pink800}" />
                                    <Label Text="{Binding PoiDistrict}" FontSize="11"
                                           TextColor="{StaticResource Pink400}" />
                                    <Label Text="{Binding NextStopHint}" FontSize="11"
                                           TextColor="{StaticResource Pink500}"
                                           IsVisible="{Binding HasHint}" />
                                </VerticalStackLayout>

                                <Label Grid.Column="2" Text="›" FontSize="20"
                                       TextColor="{StaticResource Pink400}"
                                       VerticalOptions="Center" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label x:Name="EmptyLabel" Text="Tour chưa có điểm dừng nào"
                   FontSize="13" TextColor="{StaticResource Pink300}"
                   HorizontalOptions="Center" IsVisible="False" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
