<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhAudioGuide.App.LoginPage"
             Title="Đăng nhập"
             BackgroundColor="#FFF5F5">

    <ScrollView>
        <StackLayout Padding="24" Spacing="20">

            <!-- Logo Header -->
            <Frame BackgroundColor="#FF69B4" CornerRadius="24" Padding="32" HasShadow="True">
                <StackLayout HorizontalOptions="Center">
                    <Label Text="🍜" FontSize="64" HorizontalOptions="Center"/>
                    <Label Text="Phố Ăn Vĩnh Khách" FontSize="24" FontAttributes="Bold" 
                           TextColor="White" HorizontalOptions="Center" Margin="0,12,0,0"/>
                    <Label Text="🎧 Audio Guide Đa Ngôn Ngữ" FontSize="14" 
                           TextColor="White" HorizontalOptions="Center" Opacity="0.9"/>
                </StackLayout>
            </Frame>

            <!-- Login Form -->
            <Frame BackgroundColor="White" CornerRadius="16" Padding="24" HasShadow="True">
                <StackLayout Spacing="16">
                    <Label Text="🔑 Đăng nhập" FontSize="22" FontAttributes="Bold" 
                           TextColor="#333" HorizontalOptions="Center"/>

                    <StackLayout>
                        <Label Text="👤 Tên đăng nhập" FontSize="14" TextColor="#666" Margin="0,0,0,4"/>
                        <Frame BackgroundColor="#F5F5F5" CornerRadius="12" Padding="12,8" HasShadow="False">
                            <Entry x:Name="UsernameEntry" Placeholder="Nhập tên đăng nhập" 
                                   FontSize="16" TextColor="#333"/>
                        </Frame>
                    </StackLayout>

                    <StackLayout>
                        <Label Text="🔒 Mật khẩu" FontSize="14" TextColor="#666" Margin="0,0,0,4"/>
                        <Frame BackgroundColor="#F5F5F5" CornerRadius="12" Padding="12,8" HasShadow="False">
                            <Entry x:Name="PasswordEntry" Placeholder="Nhập mật khẩu" 
                                   FontSize="16" TextColor="#333" IsPassword="True"/>
                        </Frame>
                    </StackLayout>

                    <Button x:Name="LoginButton" Text="🔑 Đăng nhập" 
                            BackgroundColor="#FF69B4" TextColor="White" 
                            CornerRadius="25" FontSize="18" FontAttributes="Bold"
                            Margin="0,8,0,0"
                            Clicked="LoginButton_Clicked"/>

                    <ActivityIndicator x:Name="LoginActivityIndicator" 
                                      Color="#FF69B4" HorizontalOptions="Center"
                                      IsRunning="False" IsVisible="False"/>
                </StackLayout>
            </Frame>

            <!-- Demo Account Section -->
            <Frame BackgroundColor="#E8F5E9" CornerRadius="16" Padding="20" HasShadow="True">
                <StackLayout>
                    <StackLayout Orientation="Horizontal" HorizontalOptions="Center">
                        <Label Text="🧪" FontSize="24"/>
                        <Label Text="Tài khoản Demo" FontSize="18" FontAttributes="Bold" 
                               TextColor="#2E7D32" VerticalOptions="Center" Margin="8,0,0,0"/>
                    </StackLayout>
                    <Label Text="Dùng thử ứng dụng với tài khoản demo" 
                           FontSize="14" TextColor="#555" HorizontalOptions="Center" Margin="0,8,0,0"/>
                    <Button x:Name="DemoButton" Text="🎮 Dùng thử" 
                            BackgroundColor="#4CAF50" TextColor="White" 
                            CornerRadius="20" Margin="0,12,0,0"
                            Clicked="DemoButton_Clicked"/>
                </StackLayout>
            </Frame>

            <!-- Plan Info -->
            <Frame BackgroundColor="#FFF8E1" CornerRadius="16" Padding="20" HasShadow="True">
                <StackLayout>
                    <StackLayout Orientation="Horizontal" HorizontalOptions="Center">
                        <Label Text="💎" FontSize="24"/>
                        <Label Text="📋 Thông tin các gói dịch vụ" FontSize="18" FontAttributes="Bold" 
                               TextColor="#F57C00" VerticalOptions="Center" Margin="8,0,0,0"/>
                    </StackLayout>
                    
                    <StackLayout Margin="0,16,0,0" Spacing="12">
                        <!-- Free Plan -->
                        <Frame BackgroundColor="White" CornerRadius="12" Padding="16" HasShadow="False">
                            <StackLayout>
                                <Label Text="📱 Miễn phí" FontSize="16" FontAttributes="Bold" TextColor="#333"/>
                                <StackLayout Orientation="Horizontal" Margin="0,8,0,0">
                                    <Label Text="✅" FontSize="14"/>
                                    <Label Text="Audio tiếng Việt" FontSize="14" TextColor="#666" Margin="4,0,0,0"/>
                                </StackLayout>
                                <StackLayout Orientation="Horizontal">
                                    <Label Text="✅" FontSize="14"/>
                                    <Label Text="Bản đồ POI cơ bản" FontSize="14" TextColor="#666" Margin="4,0,0,0"/>
                                </StackLayout>
                                <StackLayout Orientation="Horizontal">
                                    <Label Text="❌" FontSize="14"/>
                                    <Label Text="Audio tiếng Anh" FontSize="14" TextColor="#999" Margin="4,0,0,0"/>
                                </StackLayout>
                                <StackLayout Orientation="Horizontal">
                                    <Label Text="❌" FontSize="14"/>
                                    <Label Text="Chế độ Offline" FontSize="14" TextColor="#999" Margin="4,0,0,0"/>
                                </StackLayout>
                            </StackLayout>
                        </Frame>

                        <!-- Premium Plan -->
                        <Frame BackgroundColor="White" CornerRadius="12" Padding="16" HasShadow="False">
                            <StackLayout>
                                <StackLayout Orientation="Horizontal">
                                    <Label Text="💎" FontSize="16"/>
                                    <Label Text="Premium" FontSize="16" FontAttributes="Bold" 
                                           TextColor="#FF69B4" Margin="4,0,0,0"/>
                                </StackLayout>
                                <StackLayout Orientation="Horizontal" Margin="0,8,0,0">
                                    <Label Text="✅" FontSize="14"/>
                                    <Label Text="Audio đa ngôn ngữ (Việt, Anh)" FontSize="14" TextColor="#666" Margin="4,0,0,0"/>
                                </StackLayout>
                                <StackLayout Orientation="Horizontal">
                                    <Label Text="✅" FontSize="14"/>
                                    <Label Text="Chế độ Offline" FontSize="14" TextColor="#666" Margin="4,0,0,0"/>
                                </StackLayout>
                                <StackLayout Orientation="Horizontal">
                                    <Label Text="✅" FontSize="14"/>
                                    <Label Text="Thống kê nâng cao" FontSize="14" TextColor="#666" Margin="4,0,0,0"/>
                                </StackLayout>
                                <StackLayout Orientation="Horizontal">
                                    <Label Text="✅" FontSize="14"/>
                                    <Label Text="Hỗ trợ ưu tiên" FontSize="14" TextColor="#666" Margin="4,0,0,0"/>
                                </StackLayout>
                                <Button Text="✨ Nâng cấp Premium" 
                                        BackgroundColor="#FF69B4" TextColor="White" 
                                        CornerRadius="15" Margin="0,12,0,0"
                                        Clicked="UpgradeButton_Clicked"/>
                            </StackLayout>
                        </Frame>
                    </StackLayout>
                </StackLayout>
            </Frame>

            <!-- Skip Button -->
            <Button x:Name="SkipButton" Text="🚶 Tiếp tục không đăng nhập" 
                    BackgroundColor="Transparent" TextColor="#999" 
                    CornerRadius="20" FontSize="14"
                    Clicked="SkipButton_Clicked"/>

            <!-- Spacer -->
            <BoxView HeightRequest="30"/>

        </StackLayout>
    </ScrollView>

</ContentPage>
