<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhAudioGuide.App.LoginPage"
             BackgroundColor="#FFFBF5"
             Title="Đăng nhập">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20">

            <!-- Logo / Header -->
            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                <Image Source="app_logo.png" WidthRequest="80" HeightRequest="80"
                       HorizontalOptions="Center" />
                <Label Text="Phố Ăn Vĩnh Khách" FontSize="24" FontAttributes="Bold"
                       TextColor="#EC4899" HorizontalOptions="Center" />
                <Label Text="Audio Guide Đa Ngôn Ngữ" FontSize="13"
                       TextColor="#6B7280" HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- Login Form -->
            <Border BackgroundColor="White" StrokeThickness="0"
                    StrokeShape="RoundRectangle 16" Padding="20">
                <VerticalStackLayout Spacing="16">

                    <Label Text="Đăng nhập" FontSize="18" FontAttributes="Bold"
                           TextColor="#1F2937" />

                    <!-- Username Entry -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Tên đăng nhập" FontSize="13" FontAttributes="Bold"
                               TextColor="#374151" />
                        <Entry x:Name="UsernameEntry" Placeholder="Nhập tên đăng nhập"
                               FontSize="15" BackgroundColor="#F9FAFB"
                               TextColor="#1F2937" />
                    </VerticalStackLayout>

                    <!-- Password Entry -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Mật khẩu" FontSize="13" FontAttributes="Bold"
                               TextColor="#374151" />
                        <Entry x:Name="PasswordEntry" Placeholder="Nhập mật khẩu"
                               FontSize="15" BackgroundColor="#F9FAFB"
                               TextColor="#1F2937" IsPassword="True" />
                    </VerticalStackLayout>

                    <!-- Error Message -->
                    <Label x:Name="ErrorLabel" Text="" FontSize="12"
                           TextColor="#EF4444" IsVisible="False" />

                    <!-- Login Button -->
                    <Button x:Name="LoginBtn" Text="Đăng nhập" BackgroundColor="#EC4899"
                            TextColor="White" FontSize="15" FontAttributes="Bold"
                            CornerRadius="12" HeightRequest="48"
                            Clicked="OnLoginClicked" />

                    <!-- Loading -->
                    <ActivityIndicator x:Name="LoadingIndicator" IsRunning="False"
                                       Color="#EC4899" HorizontalOptions="Center"
                                       IsVisible="False" />

                    <!-- Register Link -->
                    <HorizontalStackLayout Spacing="4" HorizontalOptions="Center">
                        <Label Text="Chưa có tài khoản?" FontSize="13"
                               TextColor="#6B7280" />
                        <Label Text=" Đăng ký" FontSize="13" FontAttributes="Bold"
                               TextColor="#EC4899">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnRegisterTapped" />
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Border>

            <!-- Demo Users Section -->
            <Border BackgroundColor="#FEF3C7" StrokeThickness="0"
                    StrokeShape="RoundRectangle 12" Padding="16">
                <VerticalStackLayout Spacing="12">

                    <Label Text="🎯 Tài khoản Demo" FontSize="14" FontAttributes="Bold"
                           TextColor="#92400E" />

                    <!-- Basic Demo -->
                    <Border BackgroundColor="White" StrokeThickness="0"
                            StrokeShape="RoundRectangle 10" Padding="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="👤 demo" FontSize="13" FontAttributes="Bold"
                                       TextColor="#1F2937" />
                                <Label Text="Basic Plan (1USD) - Tính năng cơ bản"
                                       FontSize="11" TextColor="#6B7280" />
                                <Label Text="Mật khẩu: (để trống)" FontSize="10"
                                       TextColor="#9CA3AF" />
                            </VerticalStackLayout>
                            <Button Grid.Column="1" Text="Dùng thử" BackgroundColor="#E5E7EB"
                                    TextColor="#374151" FontSize="12" CornerRadius="8"
                                    Padding="12,6" Clicked="OnDemoBasicClicked" />
                        </Grid>
                    </Border>

                    <!-- Premium Demo -->
                    <Border BackgroundColor="#F0FDF4" StrokeThickness="0"
                            StrokeShape="RoundRectangle 10" Padding="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="👑 premium" FontSize="13" FontAttributes="Bold"
                                       TextColor="#059669" />
                                <Label Text="Premium Segment (10USD) - Tất cả tính năng"
                                       FontSize="11" TextColor="#047857" />
                                <Label Text="Mật khẩu: (để trống)" FontSize="10"
                                       TextColor="#6B7280" />
                            </VerticalStackLayout>
                            <Button Grid.Column="1" Text="Dùng thử" BackgroundColor="#D1FAE5"
                                    TextColor="#059669" FontSize="12" CornerRadius="8"
                                    Padding="12,6" Clicked="OnDemoPremiumClicked" />
                        </Grid>
                    </Border>

                </VerticalStackLayout>
            </Border>

            <!-- Plan Info -->
            <Border BackgroundColor="#F9FAFB" StrokeThickness="0"
                    StrokeShape="RoundRectangle 12" Padding="16">
                <VerticalStackLayout Spacing="10">

                    <Label Text="💳 Thông tin các gói dịch vụ" FontSize="14"
                           FontAttributes="Bold" TextColor="#374151" />

                    <Grid ColumnDefinitions="*,*">
                        <!-- Basic -->
                        <Border Grid.Column="0" BackgroundColor="#FEE2E2"
                                StrokeThickness="0" StrokeShape="RoundRectangle 10"
                                Padding="12" Margin="0,0,4,0">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Basic" FontSize="14" FontAttributes="Bold"
                                       TextColor="#DC2626" />
                                <Label Text="1 USD" FontSize="20" FontAttributes="Bold"
                                       TextColor="#EF4444" />
                                <Label Text="• 12 POIs cơ bản&#x0a;• Tiếng Việt/Anh&#x0a;• Audio guide&#x0a;• Bản đồ"
                                       FontSize="10" TextColor="#7F1D1D" LineHeight="1.4" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Premium -->
                        <Border Grid.Column="1" BackgroundColor="#D1FAE5"
                                StrokeThickness="0" StrokeShape="RoundRectangle 10"
                                Padding="12" Margin="4,0,0,0">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Premium" FontSize="14" FontAttributes="Bold"
                                       TextColor="#059669" />
                                <Label Text="10 USD" FontSize="20" FontAttributes="Bold"
                                       TextColor="#10B981" />
                                <Label Text="• Tất cả POIs&#x0a;• 5 ngôn ngữ&#x0a;• Audio HD&#x0a;• Analytics"
                                       FontSize="10" TextColor="#065F46" LineHeight="1.4" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- Skip / Continue as Guest -->
            <Button x:Name="SkipBtn" Text="Tiếp tục không đăng nhập"
                    BackgroundColor="Transparent" TextColor="#9CA3AF"
                    FontSize="13" Clicked="OnSkipClicked" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
