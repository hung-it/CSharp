<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhAudioGuide.App.QrScanPage"
             Title="Quét QR Code"
             BackgroundColor="#000000">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Frame Grid.Row="0" BackgroundColor="#FF69B4" CornerRadius="0" Padding="16" HasShadow="False">
            <StackLayout>
                <Label Text="📷 Quét QR Code" FontSize="22" FontAttributes="Bold" TextColor="White" 
                       HorizontalOptions="Center"/>
            </StackLayout>
        </Frame>

        <!-- Camera Preview Area -->
        <Frame Grid.Row="1" BackgroundColor="#1A1A1A" CornerRadius="0" Padding="0" HasShadow="False">
            <Grid>
                <!-- Placeholder for camera -->
                <StackLayout VerticalOptions="Center" HorizontalOptions="Center">
                    <Label Text="📷" FontSize="80" HorizontalOptions="Center"/>
                    <Label Text="Camera đang khởi tạo..." FontSize="16" TextColor="#999" 
                           HorizontalOptions="Center" Margin="0,16,0,0"/>
                </StackLayout>

                <!-- Scanning Frame Overlay -->
                <Frame WidthRequest="250" HeightRequest="250" 
                       BackgroundColor="Transparent" 
                       BorderColor="#FF69B4" 
                       CornerRadius="20" 
                       HorizontalOptions="Center" 
                       VerticalOptions="Center"
                       IsVisible="True">
                    <Frame BorderColor="#FF69B4" BorderWidth="3" CornerRadius="20" BackgroundColor="Transparent">
                        <StackLayout>
                            <!-- Corner decorations -->
                            <Grid HeightRequest="50">
                                <BoxView BackgroundColor="#FF69B4" WidthRequest="50" HeightRequest="5" 
                                         HorizontalOptions="Start" VerticalOptions="Start"/>
                                <BoxView BackgroundColor="#FF69B4" WidthRequest="5" HeightRequest="50" 
                                         HorizontalOptions="Start" VerticalOptions="Start"/>
                                <BoxView BackgroundColor="#FF69B4" WidthRequest="50" HeightRequest="5" 
                                         HorizontalOptions="End" VerticalOptions="Start"/>
                                <BoxView BackgroundColor="#FF69B4" WidthRequest="5" HeightRequest="50" 
                                         HorizontalOptions="End" VerticalOptions="Start"/>
                                <BoxView BackgroundColor="#FF69B4" WidthRequest="50" HeightRequest="5" 
                                         HorizontalOptions="Start" VerticalOptions="End"/>
                                <BoxView BackgroundColor="#FF69B4" WidthRequest="5" HeightRequest="50" 
                                         HorizontalOptions="Start" VerticalOptions="End"/>
                                <BoxView BackgroundColor="#FF69B4" WidthRequest="50" HeightRequest="5" 
                                         HorizontalOptions="End" VerticalOptions="End"/>
                                <BoxView BackgroundColor="#FF69B4" WidthRequest="5" HeightRequest="50" 
                                         HorizontalOptions="End" VerticalOptions="End"/>
                            </Grid>
                        </StackLayout>
                    </Frame>
                </Frame>

                <!-- Scanning Animation -->
                <BoxView x:Name="ScanLine" WidthRequest="230" HeightRequest="3" 
                         BackgroundColor="#00FF00" Opacity="0.8"
                         HorizontalOptions="Center" VerticalOptions="Center"
                         IsVisible="True"/>
            </Grid>
        </Frame>

        <!-- Bottom Section -->
        <Frame Grid.Row="2" BackgroundColor="#1A1A1A" CornerRadius="20" Margin="0" Padding="20" HasShadow="False">
            <StackLayout>
                <!-- Instructions -->
                <StackLayout Orientation="Horizontal" HorizontalOptions="Center">
                    <Label Text="📷" FontSize="20"/>
                    <Label Text="Hướng camera vào mã QR tại điểm tham quan" 
                           FontSize="14" TextColor="#CCCCCC" 
                           VerticalOptions="Center" Margin="8,0,0,0"/>
                </StackLayout>

                <!-- Status -->
                <Label x:Name="StatusLabel" Text="⏳ Đang quét..." 
                       FontSize="16" TextColor="#FF69B4" 
                       HorizontalOptions="Center" Margin="0,12,0,0"/>

                <!-- Loading -->
                <ActivityIndicator x:Name="LoadingIndicator" 
                                   Color="#FF69B4" HorizontalOptions="Center"
                                   IsRunning="True" IsVisible="True" Margin="0,8,0,0"/>

                <!-- Buttons -->
                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Text="❌ Đóng" 
                            BackgroundColor="#333333" TextColor="White" 
                            CornerRadius="20" Margin="0,0,8,0"
                            Clicked="CloseButton_Clicked"/>
                    <Button Grid.Column="1" Text="🔔 Thủ công" 
                            BackgroundColor="#FF69B4" TextColor="White" 
                            CornerRadius="20" Margin="8,0,0,0"
                            Clicked="ManualButton_Clicked"/>
                </Grid>
            </StackLayout>
        </Frame>

    </Grid>

</ContentPage>
