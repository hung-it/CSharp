<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:VinhKhanhAudioGuide.App"
             x:Class="VinhKhanhAudioGuide.App.PoiListPage"
             Title="Điểm Tham Quan"
             BackgroundColor="#FFF5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Frame Grid.Row="0" BackgroundColor="#FF69B4" CornerRadius="0" Padding="16" HasShadow="False">
            <StackLayout>
                <Label Text="📍 Điểm Tham Quan" FontSize="22" FontAttributes="Bold" TextColor="White" 
                       HorizontalOptions="Center"/>
            </StackLayout>
        </Frame>

        <!-- Search Bar -->
        <Frame Grid.Row="1" BackgroundColor="White" CornerRadius="0" Padding="12" HasShadow="False">
            <StackLayout>
                <Frame BackgroundColor="#F5F5F5" CornerRadius="20" Padding="12,8" HasShadow="False">
                    <StackLayout Orientation="Horizontal">
                        <Label Text="🔍" FontSize="18" VerticalOptions="Center"/>
                        <Entry x:Name="SearchEntry" Placeholder="🔍 Tìm kiếm POI..." 
                               FontSize="16" HorizontalOptions="FillAndExpand"
                               TextChanged="SearchEntry_TextChanged"/>
                    </StackLayout>
                </Frame>
            </StackLayout>
        </Frame>

        <!-- Filters -->
        <ScrollView Grid.Row="2" Orientation="Horizontal" BackgroundColor="White" Padding="12,8">
            <StackLayout Orientation="Horizontal" Spacing="8">
                <Button x:Name="AllFilterButton" Text="🏠 Tất cả" 
                        BackgroundColor="#FF69B4" TextColor="White" 
                        CornerRadius="15" Padding="12,6"
                        Clicked="AllFilterButton_Clicked"/>
                <Button x:Name="XomChieuFilterButton" Text="🏘️ Xóm Chiếu" 
                        BackgroundColor="#FFB6C1" TextColor="#333" 
                        CornerRadius="15" Padding="12,6"
                        Clicked="XomChieuFilterButton_Clicked"/>
                <Button x:Name="VinhHoiFilterButton" Text="🏠 Vĩnh Hội" 
                        BackgroundColor="#FFB6C1" TextColor="#333" 
                        CornerRadius="15" Padding="12,6"
                        Clicked="VinhHoiFilterButton_Clicked"/>
                <Button x:Name="KhanhHoiFilterButton" Text="🏪 Khánh Hội" 
                        BackgroundColor="#FFB6C1" TextColor="#333" 
                        CornerRadius="15" Padding="12,6"
                        Clicked="KhanhHoiFilterButton_Clicked"/>
            </StackLayout>
        </ScrollView>

        <!-- Sort Options -->
        <Frame Grid.Row="2" BackgroundColor="Transparent" Padding="0" Margin="0,60,0,0">
            <StackLayout Orientation="Horizontal" HorizontalOptions="End" Margin="0,0,12,0">
                <Label Text="Sắp xếp:" FontSize="12" TextColor="#666" VerticalOptions="Center"/>
                <Picker x:Name="SortPicker" Title="Sắp xếp" 
                        FontSize="12" WidthRequest="100"
                        SelectedIndexChanged="SortPicker_SelectedIndexChanged">
                    <Picker.Items>
                        <x:String>Mặc định</x:String>
                        <x:String>Theo tên</x:String>
                        <x:String>Gần nhất</x:String>
                        <x:String>Phổ biến</x:String>
                    </Picker.Items>
                </Picker>
            </StackLayout>
        </Frame>

        <!-- POI List -->
        <ScrollView Grid.Row="3" Margin="0,70,0,0">
            <StackLayout x:Name="PoiListContainer" Padding="16" Spacing="12">
                <!-- Dynamic POIs will be added here -->
            </StackLayout>
        </ScrollView>

        <!-- Empty State -->
        <Frame x:Name="EmptyStateFrame" Grid.Row="3" BackgroundColor="Transparent" 
               IsVisible="False" Padding="0" Margin="0,100,0,0">
            <StackLayout HorizontalOptions="Center" VerticalOptions="Center">
                <Label Text="😢" FontSize="64" HorizontalOptions="Center"/>
                <Label Text="Không tìm thấy POI" FontSize="18" FontAttributes="Bold" 
                       TextColor="#999" HorizontalOptions="Center" Margin="0,16,0,0"/>
                <Label Text="Thử thay đổi bộ lọc hoặc từ khóa tìm kiếm" 
                       FontSize="14" TextColor="#CCC" HorizontalOptions="Center" Margin="0,8,0,0"/>
            </StackLayout>
        </Frame>

        <!-- Loading Indicator -->
        <ActivityIndicator x:Name="LoadingIndicator" Grid.Row="3" 
                          Color="#FF69B4" HorizontalOptions="Center" 
                          VerticalOptions="Center" IsRunning="False" IsVisible="False"/>

    </Grid>

</ContentPage>
