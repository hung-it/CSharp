<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:VinhKhanhAudioGuide.App"
             x:Class="VinhKhanhAudioGuide.App.MainPage"
             Title="Trang chủ"
             BackgroundColor="#FFF5F5">

    <ScrollView>
        <StackLayout Padding="16" Spacing="16">

            <!-- Header -->
            <Frame BackgroundColor="#FF69B4" CornerRadius="16" Padding="20" HasShadow="True">
                <StackLayout>
                    <Label Text="🎊 Chào mừng đến Phố Ăn Vĩnh Khách!" 
                           FontSize="20" FontAttributes="Bold" TextColor="White" 
                           HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                    <Label x:Name="ConnectionStatusLabel" Text="⏳ Đang kết nối..." 
                           FontSize="14" TextColor="White" HorizontalOptions="Center" Margin="0,8,0,0"/>
                </StackLayout>
            </Frame>

            <!-- Quick Actions Grid -->
            <Frame BackgroundColor="White" CornerRadius="12" Padding="16" HasShadow="True">
                <StackLayout>
                    <Label Text="⚡ Truy cập nhanh" FontSize="18" FontAttributes="Bold" TextColor="#333"/>
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0" Grid.Column="0" Text="🗺️&#x0a;Bản đồ" 
                                BackgroundColor="#FFB6C1" TextColor="#333" 
                                CornerRadius="12" Margin="4" FontSize="12"
                                Clicked="MapButton_Clicked"/>
                        <Button Grid.Row="0" Grid.Column="1" Text="📷&#x0a;Quét QR" 
                                BackgroundColor="#FFB6C1" TextColor="#333" 
                                CornerRadius="12" Margin="4" FontSize="12"
                                Clicked="QrScanButton_Clicked"/>
                        <Button Grid.Row="0" Grid.Column="2" Text="✈️&#x0a;Tour" 
                                BackgroundColor="#FFB6C1" TextColor="#333" 
                                CornerRadius="12" Margin="4" FontSize="12"
                                Clicked="TourButton_Clicked"/>
                        <Button Grid.Row="1" Grid.Column="0" Text="📍&#x0a;DS POI" 
                                BackgroundColor="#FFB6C1" TextColor="#333" 
                                CornerRadius="12" Margin="4" FontSize="12"
                                Clicked="PoiListButton_Clicked"/>
                        <Button Grid.Row="1" Grid.Column="1" Text="🎧&#x0a;Audio" 
                                BackgroundColor="#FFB6C1" TextColor="#333" 
                                CornerRadius="12" Margin="4" FontSize="12"
                                Clicked="AudioButton_Clicked"/>
                        <Button Grid.Row="1" Grid.Column="2" Text="⚙️&#x0a;Cài đặt" 
                                BackgroundColor="#FFB6C1" TextColor="#333" 
                                CornerRadius="12" Margin="4" FontSize="12"
                                Clicked="SettingsButton_Clicked"/>
                    </Grid>
                </StackLayout>
            </Frame>

            <!-- Stats Section -->
            <Frame BackgroundColor="White" CornerRadius="12" Padding="16" HasShadow="True">
                <StackLayout>
                    <Label Text="📊 Hành trình của bạn" FontSize="18" FontAttributes="Bold" TextColor="#333"/>
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackLayout Grid.Column="0" HorizontalOptions="Center">
                            <Label x:Name="VisitedCountLabel" Text="0" FontSize="28" FontAttributes="Bold" 
                                   TextColor="#FF69B4" HorizontalOptions="Center"/>
                            <Label Text="Điểm đã ghé" FontSize="11" TextColor="#666" HorizontalOptions="Center"/>
                        </StackLayout>
                        <StackLayout Grid.Column="1" HorizontalOptions="Center">
                            <Label x:Name="ListenCountLabel" Text="0" FontSize="28" FontAttributes="Bold" 
                                   TextColor="#FF69B4" HorizontalOptions="Center"/>
                            <Label Text="Lượt nghe" FontSize="11" TextColor="#666" HorizontalOptions="Center"/>
                        </StackLayout>
                        <StackLayout Grid.Column="2" HorizontalOptions="Center">
                            <Label x:Name="MinutesLabel" Text="0" FontSize="28" FontAttributes="Bold" 
                                   TextColor="#FF69B4" HorizontalOptions="Center"/>
                            <Label Text="Phút nghe" FontSize="11" TextColor="#666" HorizontalOptions="Center"/>
                        </StackLayout>
                    </Grid>
                </StackLayout>
            </Frame>

            <!-- Nearby Section -->
            <Frame BackgroundColor="White" CornerRadius="12" Padding="16" HasShadow="True">
                <StackLayout>
                    <StackLayout Orientation="Horizontal">
                        <Label Text="📍 Gần bạn" FontSize="18" FontAttributes="Bold" TextColor="#333"/>
                        <ActivityIndicator x:Name="NearbyActivityIndicator" 
                                           Color="#FF69B4" WidthRequest="20" HeightRequest="20"
                                           HorizontalOptions="EndAndExpand" IsRunning="False"/>
                    </StackLayout>
                    <ScrollView Orientation="Horizontal" Margin="0,12,0,0">
                        <StackLayout x:Name="NearbyPoiContainer" Orientation="Horizontal" Spacing="12">
                            <!-- Dynamic POIs will be added here -->
                        </StackLayout>
                    </ScrollView>
                    <Label x:Name="NoNearbyLabel" Text="😴 Không có điểm gần đây" 
                           FontSize="14" TextColor="#999" HorizontalOptions="Center" 
                           IsVisible="False" Margin="0,12,0,0"/>
                </StackLayout>
            </Frame>

            <!-- Popular Section -->
            <Frame BackgroundColor="White" CornerRadius="12" Padding="16" HasShadow="True">
                <StackLayout>
                    <Label Text="🔥 Phổ biến nhất" FontSize="18" FontAttributes="Bold" TextColor="#333"/>
                    <ScrollView Orientation="Horizontal" Margin="0,12,0,0">
                        <StackLayout x:Name="PopularPoiContainer" Orientation="Horizontal" Spacing="12">
                            <!-- Dynamic POIs will be added here -->
                        </StackLayout>
                    </ScrollView>
                </StackLayout>
            </Frame>

            <!-- Language Selector -->
            <Frame BackgroundColor="White" CornerRadius="12" Padding="16" HasShadow="True">
                <StackLayout>
                    <Label Text="🌐 Ngôn ngữ" FontSize="18" FontAttributes="Bold" TextColor="#333"/>
                    <StackLayout Orientation="Horizontal" HorizontalOptions="Center" Margin="0,12,0,0">
                        <Button x:Name="VietnameseButton" Text="🇻🇳 Tiếng Việt" 
                                BackgroundColor="#FF69B4" TextColor="White" 
                                CornerRadius="20" Margin="4,0"
                                Clicked="VietnameseButton_Clicked"/>
                        <Button x:Name="EnglishButton" Text="🇬🇧 English" 
                                BackgroundColor="#E0E0E0" TextColor="#333" 
                                CornerRadius="20" Margin="4,0"
                                Clicked="EnglishButton_Clicked"/>
                    </StackLayout>
                </StackLayout>
            </Frame>

            <!-- Footer -->
            <Frame BackgroundColor="#FFE4E1" CornerRadius="12" Padding="12" HasShadow="False">
                <StackLayout HorizontalOptions="Center">
                    <Label Text="🍜 Phố Ăn Vĩnh Khách - Audio Guide" 
                           FontSize="14" TextColor="#FF69B4" HorizontalOptions="Center"/>
                    <Label Text="🎧 Hướng dẫn du lịch đa ngôn ngữ" 
                           FontSize="12" TextColor="#999" HorizontalOptions="Center"/>
                </StackLayout>
            </Frame>

            <!-- Spacer -->
            <BoxView HeightRequest="50"/>

        </StackLayout>
    </ScrollView>

</ContentPage>
