<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhAudioGuide.App.MainPage"
             BackgroundColor="#FFFBF5">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">

            <!-- 🎉 Chào mừng -->
            <Border BackgroundColor="#EC4899" StrokeThickness="0" StrokeShape="RoundRectangle 16" Padding="20">
                <VerticalStackLayout Spacing="8">
                    <Label Text="🎊 Chào mừng đến Phố Ăn Vĩnh Khách!" FontSize="18"
                           FontAttributes="Bold" TextColor="White" />
                    <Label Text="Khám phá ẩm thực Sài Gòn với hướng dẫn audio đa ngôn ngữ 🇻🇳"
                           FontSize="13" TextColor="#FDF2F8" />
                    <Button Text="📷 Quét QR Code để bắt đầu" BackgroundColor="White"
                            TextColor="#EC4899" FontSize="14" FontAttributes="Bold"
                            CornerRadius="20" HeightRequest="44" Margin="0,8,0,0"
                            Clicked="OnScanQRClicked" />
                </VerticalStackLayout>
            </Border>

            <!-- 🔗 Trạng thái kết nối -->
            <Border BackgroundColor="#F0FDF4" StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="12">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Ellipse Grid.Column="0" WidthRequest="8" HeightRequest="8" Fill="#22C55E"
                             VerticalOptions="Center" />
                    <Label Grid.Column="1" x:Name="ConnectionStatusLabel" Text="✅ Đã kết nối server"
                           FontSize="12" TextColor="#16A34A" VerticalOptions="Center" Margin="8,0,0,0" />
                    <Label Grid.Column="2" x:Name="LastSyncLabel" Text="vừa xong" FontSize="11"
                           TextColor="#6B7280" VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- 🎯 Menu nhanh -->
            <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">

                <!-- 🗺️ Bản đồ -->
                <Border Grid.Column="0" Grid.Row="0" BackgroundColor="#DBEAFE" StrokeThickness="0"
                        StrokeShape="RoundRectangle 14" Padding="16">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="🗺️" FontSize="32" HorizontalOptions="Center" />
                        <Label Text="Bản đồ" FontSize="13" TextColor="#1E40AF"
                               FontAttributes="Bold" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMapClicked" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- 📷 Quét QR -->
                <Border Grid.Column="1" Grid.Row="0" BackgroundColor="#FCE7F3" StrokeThickness="0"
                        StrokeShape="RoundRectangle 14" Padding="16">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="📷" FontSize="32" HorizontalOptions="Center" />
                        <Label Text="Quét QR" FontSize="13" TextColor="#BE185D"
                               FontAttributes="Bold" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnScanQRClicked" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- ✈️ Tour -->
                <Border Grid.Column="2" Grid.Row="0" BackgroundColor="#ECFDF5" StrokeThickness="0"
                        StrokeShape="RoundRectangle 14" Padding="16">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="✈️" FontSize="32" HorizontalOptions="Center" />
                        <Label Text="Tour" FontSize="13" TextColor="#047857"
                               FontAttributes="Bold" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnToursClicked" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- 📍 DS POI -->
                <Border Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1"
                        BackgroundColor="#FEF3C7" StrokeThickness="0"
                        StrokeShape="RoundRectangle 14" Padding="16">
                    <VerticalStackLayout Spacing="8">
                        <HorizontalStackLayout Spacing="12">
                            <Label Text="📍" FontSize="28" VerticalOptions="Center" />
                            <VerticalStackLayout>
                                <Label Text="12 Điểm tham quan" FontSize="14" TextColor="#B45309"
                                       FontAttributes="Bold" />
                                <Label Text="Xóm Chiếu - Vĩnh Hội - Khánh Hội" FontSize="11" TextColor="#92400E" />
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPoiListClicked" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- 🎧 Audio -->
                <Border Grid.Column="2" Grid.Row="1" BackgroundColor="#F3E8FF" StrokeThickness="0"
                        StrokeShape="RoundRectangle 14" Padding="16">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="🎧" FontSize="28" HorizontalOptions="Center" />
                        <Label Text="Audio" FontSize="13" TextColor="#7C3AED"
                               FontAttributes="Bold" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAudioListClicked" />
                    </Border.GestureRecognizers>
                </Border>
            </Grid>

            <!-- 📊 Thống kê cá nhân -->
            <Border BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 14" Padding="18">
                <VerticalStackLayout Spacing="12">
                    <Label Text="📊 Hành trình của bạn" FontSize="15" FontAttributes="Bold"
                           TextColor="#1F2937" />
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center">
                            <Label x:Name="MyPoiVisitCount" Text="0" FontSize="28"
                                   FontAttributes="Bold" TextColor="#EC4899"
                                   HorizontalOptions="Center" />
                            <Label Text="Điểm đã ghé" FontSize="10" TextColor="#6B7280"
                                   HorizontalOptions="Center" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                            <Label x:Name="MyListenCount" Text="0" FontSize="28"
                                   FontAttributes="Bold" TextColor="#3B82F6"
                                   HorizontalOptions="Center" />
                            <Label Text="Lượt nghe" FontSize="10" TextColor="#6B7280"
                                   HorizontalOptions="Center" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center">
                            <Label x:Name="MyListenTime" Text="0" FontSize="28"
                                   FontAttributes="Bold" TextColor="#10B981"
                                   HorizontalOptions="Center" />
                            <Label Text="Phút nghe" FontSize="10" TextColor="#6B7280"
                                   HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- 📍 Gần bạn -->
            <Border BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 14" Padding="18">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="📍 Gần bạn" FontSize="15" FontAttributes="Bold"
                               TextColor="#1F2937" />
                        <Button Grid.Column="1" Text="🗺️ Bản đồ" BackgroundColor="#EFF6FF"
                                TextColor="#2563EB" FontSize="12" CornerRadius="8"
                                Padding="12,6" Clicked="OnMapClicked" />
                    </Grid>
                    <CollectionView x:Name="NearbyPoisCollectionView" HeightRequest="120">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border BackgroundColor="#F0F9FF" StrokeThickness="0"
                                        StrokeShape="RoundRectangle 10" Padding="12" Margin="0,0,0,6">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                                            <Label Text="{Binding Name}" FontSize="13"
                                                   FontAttributes="Bold" TextColor="#1E40AF" />
                                            <Label Text="{Binding DistanceText}" FontSize="11"
                                                   TextColor="#3B82F6" />
                                        </VerticalStackLayout>
                                        <Button Grid.Column="1" Text="▶" BackgroundColor="#3B82F6"
                                                TextColor="White" CornerRadius="16" WidthRequest="40"
                                                HeightRequest="40" Padding="0"
                                                Clicked="OnNearbyPlayClicked" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <Label x:Name="NoNearbyLabel" Text="🔄 Đang tìm POI gần bạn..."
                           FontSize="12" TextColor="#9CA3AF" HorizontalOptions="Center"
                           IsVisible="True" />
                </VerticalStackLayout>
            </Border>

            <!-- 🔥 Phổ biến -->
            <Border BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 14" Padding="18">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="🔥 Phổ biến nhất" FontSize="15"
                               FontAttributes="Bold" TextColor="#1F2937" />
                        <Button Grid.Column="1" Text="📋 Xem tất cả" BackgroundColor="#FDF2F8"
                                TextColor="#EC4899" FontSize="12" CornerRadius="8"
                                Padding="12,6" Clicked="OnPoiListClicked" />
                    </Grid>
                    <CollectionView x:Name="PopularPoisCollectionView" HeightRequest="150">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border BackgroundColor="#FDF2F8" StrokeThickness="0"
                                        StrokeShape="RoundRectangle 10" Padding="12" Margin="0,0,0,6">
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                        <Label Grid.Column="0" Text="{Binding Rank}" FontSize="16"
                                               FontAttributes="Bold" TextColor="#F59E0B"
                                               VerticalOptions="Center" WidthRequest="28" />
                                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                                            <Label Text="{Binding PoiName}" FontSize="13"
                                                   FontAttributes="Bold" TextColor="#831743" />
                                            <Label Text="{Binding District}" FontSize="11"
                                                   TextColor="#BE185D" />
                                        </VerticalStackLayout>
                                        <Border Grid.Column="2" BackgroundColor="#FCE7F3"
                                                StrokeThickness="0" StrokeShape="RoundRectangle 10"
                                                Padding="8,4">
                                            <Label Text="{Binding ListenCount}" FontSize="11"
                                                   FontAttributes="Bold" TextColor="#EC4899" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <!-- 🌐 Ngôn ngữ -->
            <Border BackgroundColor="#F9FAFB" StrokeThickness="0" StrokeShape="RoundRectangle 14" Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Label Text="🌐 Ngôn ngữ" FontSize="13" FontAttributes="Bold"
                           TextColor="#374151" />
                    <HorizontalStackLayout Spacing="10">
                        <Button x:Name="LangViBtn" Text="🇻🇳 Tiếng Việt" BackgroundColor="#EC4899"
                                TextColor="White" CornerRadius="20" FontSize="13"
                                Padding="16,8" Clicked="OnLanguageViClicked" />
                        <Button x:Name="LangEnBtn" Text="🇬🇧 English" BackgroundColor="#E5E7EB"
                                TextColor="#374151" CornerRadius="20" FontSize="13"
                                Padding="16,8" Clicked="OnLanguageEnClicked" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- 🔄 Đồng bộ -->
            <Button x:Name="RefreshBtn" Text="🔄 Đồng bộ dữ liệu" BackgroundColor="#F3F4F6"
                    TextColor="#374151" FontSize="13" CornerRadius="10"
                    HeightRequest="44" Clicked="OnRefreshClicked" />

            <ActivityIndicator x:Name="LoadingIndicator" IsRunning="False"
                               Color="#EC4899" HorizontalOptions="Center"
                               IsVisible="False" />

            <!-- 📌 Footer -->
            <Label Text="🍜 Phố Ăn Vĩnh Khách - Audio Guide" FontSize="11"
                   TextColor="#9CA3AF" HorizontalOptions="Center" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
