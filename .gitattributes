# Enforce LF for all files to avoid CRLF/LF warnings on Windows
* text=auto

# Force LF for specific file types that should always use LF
*.cs text eol=lf
*.xaml text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.md text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.sh text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.txt text eol=lf
*.sql text eol=lf
*.props text eol=lf
*.targets text eol=lf

# Binary files - no conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.exe binary
*.dll binary
*.mp3 binary
*.wav binary
*.mp4 binary
*.ttf binary
*.woff binary
*.woff2 binary
